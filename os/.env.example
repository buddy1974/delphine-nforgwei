# DELPHINE ECOSYSTEM OS — environment variables (TEMPLATE — no real values here!)
# Copy to .env.local for development. Set the same in Vercel for production.

# Supabase project: mohogdfdzmewwvgcizga (the single ecosystem DB)
NEXT_PUBLIC_SUPABASE_URL=https://mohogdfdzmewwvgcizga.supabase.co
# Anon (publishable) key — Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY, never expose with NEXT_PUBLIC_.
# Required from Phase D (data modules). Not needed for the Phase C shell.
SUPABASE_SERVICE_ROLE_KEY=

# Secure preview links — SERVER ONLY. Required in production.
# Local development falls back to a non-production-only dev secret if unset.
PREVIEW_TOKEN_SECRET=

# Public Delphine website origin used for secure rendering-plane previews.
# Production example: https://www.delphine-nforgwei.com
# Local development default if unset: http://localhost:5173
DELPHINE_PUBLIC_SITE_URL=

# Brand public-site origins for the secure preview plane.
# Delphine (P1E), E-Woman (H8.1), and SMCC (H8.2) have previewMode "secure".
# DRIMP remains "generic" — no URL required yet.
# Production values — no trailing slash.
SMCC_PUBLIC_SITE_URL=https://www.smcc.solutions
EWOMAN_PUBLIC_SITE_URL=https://e-womanconference.online
DRIMP_PUBLIC_SITE_URL=

# Phase J (Telegram notifications) — leave empty until then
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Phase K (AI Content Studio) — leave empty until then
OPENAI_API_KE